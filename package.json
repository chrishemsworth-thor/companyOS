{
  "name": "companyos",
  "version": "0.1.0",
  "private": true,
  "description": "CompanyOS — AI-agent-first business operating system. Phase 0: data spine & agent orchestration on Cloudflare.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply companyos-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply companyos-db --remote",
    "seed:local": "node scripts/seed-local.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "hono": "^4.7.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250405.0",
    "typescript": "^5.7.0",
    "vitest": "~3.0.0",
    "wrangler": "^4.0.0"
  }
}
